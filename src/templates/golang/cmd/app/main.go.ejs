package main

import (
	"log/slog"
	"os"

	"<%= projectName.replace(/^@/, "") %>/internal/seed"
)

func main() {
	os.Exit(run(seed.Greet))
}

type greetFunc func(string, seed.Language) (seed.SeedResult, error)

func run(greet greetFunc) int {
	slog.SetDefault(slog.New(slog.NewJSONHandler(os.Stderr, nil)))

	result, err := greet("World", seed.DefaultLanguage)
	if err != nil {
		slog.Error("greeting failed", "error", err)
		return 1
	}

	slog.Info("greeting ready", "greeting", result.Greeting, "language", result.Language.String())
	return 0
}
