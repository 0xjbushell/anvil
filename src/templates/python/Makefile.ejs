COVERAGE_THRESHOLD ?= 80
PY_DEV ?= --extra dev

.PHONY: lint format typecheck security test coverage deadcode crap audit mutate quality check fix

# Tier 1 — pre-commit hook
lint: ## Run all linters (Ruff built-in + Flake8 custom ANV rules)
	uv run $(PY_DEV) ruff check .
	uv run $(PY_DEV) --with-editable tools/flake8-plugin flake8 --select=ANV src tests

format: ## Check formatting
	uv run $(PY_DEV) ruff format --check .

typecheck: ## Run type checker
	uv run $(PY_DEV) mypy src

security: ## Run gitleaks secret scan
	gitleaks detect --source . --no-git

# Tier 2 — pre-push hook
test: ## Run tests
	uv run $(PY_DEV) pytest

coverage: ## Run tests + enforce coverage thresholds
	uv run $(PY_DEV) pytest --cov=src --cov-fail-under=$(COVERAGE_THRESHOLD)

deadcode: ## Detect unused code
	uv run $(PY_DEV) vulture src

crap: ## Compute CRAP scores
	uv run $(PY_DEV) pytest --crap

audit: ## Audit dependencies for vulnerabilities
	uv export --extra dev --format requirements-txt --no-hashes | uv run $(PY_DEV) pip-audit --progress-spinner off --skip-editable -r /dev/stdin

# Tier 3 — on-demand
mutate: ## Run mutation testing
	uv run $(PY_DEV) mutmut run

quality: check mutate ## Run ALL checks (tier 1 + 2 + 3)

# Convenience
check: lint format typecheck security test coverage deadcode crap audit ## Run tier 1 + tier 2

fix: ## Auto-fix lint + format issues
	uv run $(PY_DEV) ruff check --fix .
	uv run $(PY_DEV) ruff format .
