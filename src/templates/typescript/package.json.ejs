<%
const pm = packageManager ?? "npm";
const auditScript = pm === "bun" ? "bun audit --audit-level high" : `${pm} audit`;
const crapScript = pm === "bun" ? "bun run tools/crap-score.ts" : "tsx tools/crap-score.ts";
const devDependencies = {
  "@eslint/js": "^9.0.0",
  "@stryker-mutator/core": "^8.0.0",
  "@stryker-mutator/vitest-runner": "^8.0.0",
  "@types/node": "^22.0.0",
  "@typescript-eslint/eslint-plugin": "^8.0.0",
  "@typescript-eslint/parser": "^8.0.0",
  "@vitest/coverage-v8": "^3.0.0",
  "eslint": "^9.0.0",
  "eslint-plugin-import": "^2.31.0",
  "eslint-plugin-security": "^3.0.0",
  "knip": "^5.0.0",
  "prettier": "^3.0.0",
  "tsx": "^4.19.0",
  "typescript": "^5.0.0",
  "typescript-eslint": "^8.0.0",
  "vitest": "^3.0.0",
};
%>{
  "name": "<%= projectName %>",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "deadcode": "knip",
    "crap": "<%= crapScript %>",
    "audit": "<%= auditScript %>",
    "mutate": "stryker run"
  },
  "dependencies": {
    "pino": "^9.5.0"
  },
  "devDependencies": <%- JSON.stringify(devDependencies, null, 2).replace(/\n/g, "\n  ") %>
}
